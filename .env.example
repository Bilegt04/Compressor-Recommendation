# Copy to `.env` and edit. `.env` is git-ignored.
# Most users will NOT need to change any of these for local testing.

# Enable thesis / OAM features (raw routes, export CSVs, dev panel in UI).
# Default: false (user-test build). Set to "true" to re-enable.
ENABLE_OAM_FEATURES=false

# Upload size limit in bytes. Default: 25 MB.
MAX_UPLOAD_BYTES=26214400

# CORS allowed origins. Default: "*" (anywhere). In production, set this to
# your deployed frontend URL, comma-separated for multiple, e.g.:
# CORS_ORIGINS=https://yourapp.onrender.com
CORS_ORIGINS=*

# Server port. Platforms like Render/Railway set $PORT automatically and
# this is ignored. Locally uvicorn uses 8000 by default.
# PORT=8000
